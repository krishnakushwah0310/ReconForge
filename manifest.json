{
  "manifest_version": 4,
  "name": "ReconForge",
  "version": "3.4",
  "description": "Professional recon command generator for bug bounty & penetration testing",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting"]
}
